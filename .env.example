# 飞书 AI Agent 环境变量配置示例
# 复制为 .env 并填入实际值

# ==================== 智谱 GLM（已配置）====================
# 智谱 API Key（用于规划层 GLM-4-Flash + 视觉层 GLM-4V-Flash）
# 当前已填入用户提供的 Key，直接使用即可
ZHIPU_API_KEY = "e539790a8240487c90e89c889f814b4f.1H5t3p9QsiOJuWn5"

# ==================== 视觉模型选择 ===========================
# zhipu: 使用智谱 GLM-4V-Flash（默认，免费）
# modelscope: 使用 ModelScope UI-TARS（需额外配置）
VISION_PROVIDER = "zhipu"

# ==================== ModelScope UI-TARS（备选）=============
# MODELSCOPE_API_KEY = "your_modelscope_api_key"

# ==================== 飞书开放平台 ==========================
# 飞书应用凭证（用于 API 验证层）
FEISHU_APP_ID = ""
FEISHU_APP_SECRET = ""

# ==================== Agent 执行配置 =======================
MAX_RETRY = "3"
HUMAN_IN_LOOP_ON_ERROR = "true"
LOG_LEVEL = "INFO"
