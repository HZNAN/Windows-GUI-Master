# LLM 模型配置（必填，兼容 OpenAI API 格式的任意厂商：火山/小米/智谱/OpenAI 等）
LLM_API_KEY=your-api-key
LLM_BASE_URL=https://your-provider.com/api/v3
LLM_MODEL=your-model-name

# Agent 执行配置（可选）
MAX_RETRY=3
SCREENSHOT_INTERVAL=0.5
STEP_TIMEOUT=30

# ReactAgent 配置（可选）
AGENT_MAX_STEPS=15          # 最大执行步数
AGENT_HISTORY_WINDOW=3      # 历史窗口大小
AGENT_TURN_DELAY=0.3        # 回合间等待（秒），给 UI 时间渲染

# LLM 模型配置（可选）
LLM_TEMPERATURE=0.1         # 采样温度，越低越确定性
LLM_MAX_TOKENS=1500         # 最大生成 token 数
LLM_TOP_P=1.0               # 核采样概率

# 日志（可选）
LOG_LEVEL=INFO

# 虚拟光标配置（可选）
# 相对路径: 相对于 PROJECT_ROOT/cursors/ 目录，如 "universe"
# 绝对路径: Windows 以盘符(C:)开头，Linux 以 / 开头
VIRTUAL_CURSOR_PATH=universe
VIRTUAL_CURSOR_DURATION=0.3   # 移动时长（秒），越小越快
VIRTUAL_CURSOR_FPS=60        # 帧率，越高越平滑
VIRTUAL_CURSOR_AMPLITUDE=15   # 曲线幅度扰动（像素）

# ACP 协议配置（可选）
ACP_HOST=localhost
ACP_PORT=8765
ACP_TOKEN=              # Bearer token，为空则禁用认证
