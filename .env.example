# LLM 模型配置（必填，兼容 OpenAI API 格式的任意厂商：火山/小米/智谱/OpenAI 等）
LLM_API_KEY=your-api-key
LLM_BASE_URL=https://your-provider.com/api/v3
LLM_MODEL=your-model-name

# LLM 参数（可选）
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1500
LLM_TOP_P=1.0

# 截图 / 坐标网格配置（可选）
GRID_SIZE=1000             # 正方形简写，等同于 GRID_WIDTH=1000 GRID_HEIGHT=1000
# GRID_WIDTH=1000          # 截图缩放宽度（单独设置时覆盖 GRID_SIZE）
# GRID_HEIGHT=800          # 截图缩放高度

# ReactAgent 配置（可选）
AGENT_MAX_STEPS=15          # 最大执行步数
AGENT_HISTORY_WINDOW=3      # 历史窗口大小
AGENT_TURN_DELAY=0.3        # 回合间等待（秒），给 UI 时间渲染

# 虚拟光标配置（可选）
VIRTUAL_CURSOR_PATH=universe
VIRTUAL_CURSOR_DURATION=0.5
VIRTUAL_CURSOR_FPS=60
VIRTUAL_CURSOR_AMPLITUDE=15

# ACP 协议配置（可选）
ACP_HOST=localhost
ACP_PORT=8765
ACP_TOKEN=              # Bearer token，为空则禁用认证

# 输入模式（可选）
INPUT_MODE=message       # "message" | "virtual" | "normal"
